    <bib:Article rdf:about="https://journals.sagepub.com/doi/10.1177/0964528420964214">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf rdf:resource="urn:issn:0964-5284"/>
        <dc:publisher>
