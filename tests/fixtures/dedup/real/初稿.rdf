        <dc:subject>
           <z:AutomaticTag><rdf:value>中医临床疗效</rdf:value></z:AutomaticTag>
        </dc:subject>
        <dc:subject>
           <z:AutomaticTag><rdf:value>中医软指标</rdf:value></z:AutomaticTag>
