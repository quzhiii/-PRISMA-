    <bib:Article rdf:about="https://doi.org/10.1177/0272989X211027181">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf rdf:resource="urn:issn:0272-989X"/>
        <dc:publisher>
            <foaf:Organization>
               <foaf:name>SAGE Publications Inc STM</foaf:name>
