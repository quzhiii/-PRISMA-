            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-02-25 13:47:09</dcterms:dateSubmitted>
        <bib:pages>348-355</bib:pages>
        <z:citationKey>bernalInterruptedTimeSeries2017a</z:citationKey>
    </bib:Article>
    <bib:Journal rdf:about="urn:issn:0300-5771">
