    <bib:Article rdf:about="https://kns.cnki.net/KCMS/detail/detail.aspx?dbcode=CJFQ&amp;dbname=CJFDAUTO&amp;filename=WRKX202408002">
        <z:itemType>journalArticle</z:itemType>
        <dcterms:isPartOf rdf:resource="urn:issn:1003-2800"/>
        <bib:authors>
            <rdf:Seq>
                <rdf:li>
                   <foaf:Person><foaf:surname>张敬华</foaf:surname></foaf:Person>
